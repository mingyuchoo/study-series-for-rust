# Rust / Cargo build output
/target/

# This repository keeps lockfiles out of the examples/workspaces.
/Cargo.lock

# Dioxus/Tauri frontend distribution output.
# Keep the directory itself present so Tauri's generate_context! can compile
# before the frontend has been built.
/presentation_frontend/dist/*
!/presentation_frontend/dist/.gitignore
!/presentation_frontend/dist/.gitkeep

# Root-level frontend distribution output, if generated by a tool.
/dist/

# Tauri CLI generated schemas and packaged artifacts can be regenerated.
/presentation_backend/gen/schemas/
/presentation_backend/target/
/presentation_backend/.tauri/

# Dioxus transient output/cache.
/presentation_frontend/.dioxus/
/presentation_frontend/.dx/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local overrides
.env
.env.*
!.env.example

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
